{
  "version": 2,
  "name": "clinica-saas",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/**",
          "node_modules/pg/**",
          "node_modules/pg-hstore/**",
          "node_modules/sequelize/**"
        ]
      }
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client/browser"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/login", "destination": "/client/index.html" },
    { "source": "/register", "destination": "/client/index.html" },
    { "source": "/dashboard/:path*", "destination": "/client/index.html" },
    { "source": "/:path*", "destination": "/client/:path*" }
  ],
  "cleanUrls": true
}
