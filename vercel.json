{
  "version": 2,
  "name": "clinica-888-final",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/**",
          "server/node_modules/pg/**",
          "server/node_modules/pg-hstore/**",
          "server/node_modules/pg-pool/**",
          "server/node_modules/pg-types/**",
          "server/node_modules/pg-int8/**",
          "server/node_modules/postgres-array/**",
          "server/node_modules/postgres-bytea/**",
          "server/node_modules/postgres-date/**",
          "server/node_modules/postgres-interval/**"
        ]
      }
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client/browser"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|woff2?|ttf|eot|pdf|txt))",
      "destination": "/client/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "true"
  }
}
