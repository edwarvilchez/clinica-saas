{
  "version": 2,
  "name": "clinica-saas",
  "builds": [
    {
      "src": "server/src/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/**",
          "node_modules/pg/**",
          "node_modules/pg-hstore/**",
          "node_modules/sequelize/**"
        ]
      }
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client/browser"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "server/src/index.js" },
    { "source": "/(.*\\.[^/]+)", "destination": "/client/$1" },
    { "source": "/(.*)", "destination": "/client/index.html" }
  ]
}
